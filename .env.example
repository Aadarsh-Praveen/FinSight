# .env.example — copy this to `.env` and fill in real values. NEVER commit `.env`.

# ─── Google Cloud ────────────────────────────────────────────────────────────
# Your GCP project ID (create one and enable billing first)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region for Cloud Run + BigQuery jobs. Keep this consistent everywhere.
GOOGLE_CLOUD_LOCATION=us-central1

# ─── Model auth: choose ONE path ─────────────────────────────────────────────
# Path A (recommended for deploy): use Vertex AI. Set to TRUE and rely on gcloud ADC.
#   Requires: gcloud auth application-default login
# Path B (quick local prototyping): use an AI Studio API key. Set to FALSE and fill GOOGLE_API_KEY.
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Only needed if GOOGLE_GENAI_USE_VERTEXAI=FALSE. Get a free key from Google AI Studio.
GOOGLE_API_KEY=

# ─── BigQuery ────────────────────────────────────────────────────────────────
# Project where BigQuery jobs run/are billed (usually same as GOOGLE_CLOUD_PROJECT)
BIGQUERY_PROJECT=your-gcp-project-id

# Default dataset to investigate. thelook_ecommerce is a free public dataset.
BIGQUERY_DATASET=bigquery-public-data.thelook_ecommerce

# ─── Models ──────────────────────────────────────────────────────────────────
# Fast model for routing + worker sub-agents
MODEL_ROUTER=gemini-2.5-flash
MODEL_WORKER=gemini-2.5-flash
# Stronger model for the verifier + final report writer
MODEL_VERIFIER=gemini-2.5-pro

# ─── MCP Toolbox ─────────────────────────────────────────────────────────────
# URL of the locally running MCP Toolbox server (default port 5000)
TOOLBOX_URL=http://127.0.0.1:5000

# ─── Observability (optional; enabled in Phase 8) ────────────────────────────
# Set to TRUE to export traces to Cloud Trace via OpenTelemetry
ENABLE_TRACING=FALSE

# ─── Verifier (Phase 7 / Phase 9 ablation) ────────────────────────────────────
# Set to FALSE to run the orchestrator without the verifier critic + retry loop
# (the "multi-agent without verifier" arm of the Phase 9 ablation). Defaults to TRUE.
ENABLE_VERIFIER=TRUE
